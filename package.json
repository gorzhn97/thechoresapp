        "uuid": "^11.0.5"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/express": "^5.0.0",
        "@types/node": "^22.10.1",
        "@types/passport-jwt": "^4.0.1",
        "prisma": "^6.5.0",
        "ts-node": "^10.9.2",

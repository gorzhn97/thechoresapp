        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/throttler": "^6.4.0",
        "@prisma/client": "^6.5.0",
        "bcrypt": "^5.1.1",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "reflect-metadata": "^0.2.2",
